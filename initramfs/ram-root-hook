#!/usr/bin/bash
# Icarus RAM-Root Hook - Ascend from slow storage into RAM.
# After this, the physical root can be unplugged. Speed: 40 GB/s.

run_hook() {
    local root_dev root_type real_root ram_root overlay_dir upperdir workdir persistent
    root_dev=$(getarg root=)
    root_type=$(getarg rootfstype=)
    real_root="/new_root"
    ram_root="/ram_root"

    persistent=$(getarg icarus.persistent=)
    if [ -n "$persistent" ]; then
        upperdir="/overlay_upper"
        workdir="/overlay_work"
        overlay_dir="/overlay"
        mkdir -p "$upperdir" "$workdir" "$overlay_dir"
    fi

    echo ":: Icarus RAM-Root: mounting physical root (read-only)..."
    mkdir -p "$real_root"
    mount -t "$root_type" -o ro "$root_dev" "$real_root"

    echo ":: Creating RAM disk (80% of total memory)..."
    local memtotal_kb=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    local tmpfs_size=$(( memtotal_kb * 80 / 100 ))k
    mount -t tmpfs -o size="$tmpfs_size",mode=0755 tmpfs "$ram_root"

    echo ":: Copying root filesystem into RAM..."
    rsync -a --exclude='/proc' --exclude='/sys' --exclude='/dev' \
          --exclude='/run' --exclude='/tmp' --exclude='/mnt' \
          "$real_root/" "$ram_root/"


    mkdir -p "$ram_root"/{proc,sys,dev,run,tmp,mnt}

    if [ -n "$persistent" ]; then
        echo ":: Enabling persistent overlay on $persistent..."
        mount -t ext4 "$persistent" "$upperdir"
        mount -t overlay overlay -o lowerdir="$ram_root",upperdir="$upperdir",workdir="$workdir" "$overlay_dir"

        ram_root="$overlay_dir"
    fi

    echo ":: Switching root into RAM..."
    umount "$real_root"


    exec switch_root "$ram_root" /sbin/init
}

