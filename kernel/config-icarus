# Icarus kernel – key config overrides
CONFIG_PREEMPT=y
CONFIG_HZ=1000
CONFIG_HZ_1000=y
CONFIG_NO_HZ_FULL=y
CONFIG_RCU_NOCB_CPU=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y
CONFIG_HUGETLBFS=y
CONFIG_ZRAM=y
CONFIG_ZSMALLOC=y
CONFIG_LZ4_COMPRESS=y
CONFIG_LZ4_DECOMPRESS=y

# Intel GPU for UMA/SVM
CONFIG_DRM_I915=m
CONFIG_DRM_I915_GVT=n
CONFIG_DRM_I915_PRELIMINARY_HW_SUPPORT=n

# Disable mitigations
CONFIG_RETPOLINE=n
CONFIG_PAGE_TABLE_ISOLATION=n
CONFIG_MITIGATION_RETPOLINE=n
CONFIG_MITIGATION_PAGE_TABLE_ISOLATION=n
CONFIG_MITIGATION_SPECTRE_V2=n
CONFIG_MITIGATION_SRBDS=n
CONFIG_MITIGATION_SSB=n
CONFIG_MITIGATION_L1TF=n
CONFIG_MITIGATION_MDS=n
CONFIG_MITIGATION_TAA=n
CONFIG_MITIGATION_MMIO_STALE_DATA=n
CONFIG_MITIGATION_RFDS=n
CONFIG_MITIGATION_SPECTRE_V1=n
CONFIG_MITIGATION_SPECTRE_BHB=n
CONFIG_MITIGATION_SPECTRE_V3A=n
CONFIG_MITIGATION_SPEC_STORE_BYPASS=n
CONFIG_MITIGATION_UNRET_ENTRY=n

# CPU scheduling & power
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_CPU_IDLE_GOV_LADDER=n
CONFIG_CPU_IDLE_GOV_MENU=n
CONFIG_CPU_IDLE_GOV_TEO=y
CONFIG_INTEL_IDLE=y
CONFIG_INTEL_PSTATE=y

# Filesystem & tmpfs
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_OVERLAY_FS=m

# Needed for initramfs
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_XZ=y
CONFIG_RD_LZ4=y